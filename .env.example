# Shared
ENV=local
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=attendance
POSTGRES_USER=attendance
POSTGRES_PASSWORD=attendance
DATABASE_URL=

# AI Service
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Pipeline
PIPELINE_HOST=0.0.0.0
PIPELINE_PORT=8002
CAMERA_SOURCE=0

# Event Bus (Redis Streams)
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_AI_EVENTS=ai.backend.events
REDIS_STREAM_PIPELINE_EVENTS=pipeline.backend.events
REDIS_STREAM_BACKEND_PIPELINE=backend.pipeline.events
REDIS_CONSUMER_GROUP=backend-consumers
REDIS_CONSUMER_NAME=backend-1
REDIS_BLOCK_MS=5000
REDIS_BATCH_SIZE=20
ENABLE_EVENT_CONSUMER=true

# Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=attendance

# Frontend
FRONTEND_PORT=3000
