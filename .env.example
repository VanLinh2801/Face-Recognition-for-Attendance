# ============================================================
#  SHARED ENVIRONMENT — face_attend docker-compose
#  Usage: 
#    1. Copy this file to .env.app:  cp .env.example .env.app
#    2. Update values in .env.app if needed
#    3. Run: docker compose up --build
# ============================================================

# Host Ports (map Docker service ports → your machine)
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
QDRANT_HTTP_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334
BACKEND_HOST_PORT=8000
AI_SERVICE_HOST_PORT=8001
PIPELINE_HOST_PORT=8002
FRONTEND_HOST_PORT=3000

MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_RTMP_PORT=1935
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_ICE_PORT=8189

# ============================================================
#  PostgreSQL
# ============================================================
POSTGRES_DB=attendance
POSTGRES_USER=attendance
POSTGRES_PASSWORD=attendance

# ============================================================
#  AI Service
# ============================================================
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ============================================================
#  Pipeline
# ============================================================
PIPELINE_HOST=0.0.0.0
PIPELINE_PORT=8002
CAMERA_SOURCE=0

# ============================================================
#  Event Bus (Redis Streams)
# ============================================================
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_AI_EVENTS=ai_backend
REDIS_STREAM_PIPELINE_EVENTS=pipeline.backend.events
REDIS_STREAM_BACKEND_PIPELINE=pipeline_backend
REDIS_CONSUMER_GROUP=backend-consumers
REDIS_CONSUMER_NAME=backend-1
REDIS_BLOCK_MS=5000
REDIS_BATCH_SIZE=20
ENABLE_EVENT_CONSUMER=true

# ============================================================
#  Business Rules / Retention
# ============================================================
THROTTLE_BUSINESS_SECONDS=30
FILTER_RETENTION_DAYS=30
MEDIA_RETENTION_DAYS_RECOGNITION=30
MEDIA_RETENTION_DAYS_UNKNOWN=30
MEDIA_RETENTION_DAYS_SPOOF=30
MEDIA_CLEANUP_ENABLED=false
MEDIA_CLEANUP_INTERVAL_DAYS=1
MEDIA_CLEANUP_BATCH_SIZE=500

# ============================================================
#  JWT / WebSocket Auth
# ============================================================
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=change-me
JWT_ISSUER=face-recognition-backend
JWT_AUDIENCE=face-recognition-clients
JWT_ACCESS_EXPIRES_SECONDS=900
JWT_REFRESH_EXPIRES_SECONDS=604800
AUTH_BCRYPT_ROUNDS=12
WS_ENABLE=true
WS_MAX_CONNECTIONS=200
WS_QUEUE_SIZE=200
WS_HEARTBEAT_SECONDS=20

# ============================================================
#  MinIO
# ============================================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=attendance
PIPELINE_MINIO_BUCKET=face-recognition

# ============================================================
#  App Settings
# ============================================================
LOG_LEVEL=INFO
ENV=production

# ============================================================
#  Backend
# ============================================================
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_SEED_ADMIN_USERNAME=admin
AUTH_SEED_ADMIN_PASSWORD=admin123
JWT_ACCESS_EXPIRES_SECONDS=86400

# ============================================================
#  AI Service — GPU vs CPU
#  Default: CUDAExecutionProvider (requires nvidia-docker)
#  Change to CPUExecutionProvider if no GPU available
# ============================================================
ONNX_EXECUTION_PROVIDER=CUDAExecutionProvider
QDRANT_COLLECTION=person_faces_antelopev2
INSIGHTFACE_MODEL_NAME=antelopev2
INSIGHTFACE_CTX_ID=0
RECOGNITION_THRESHOLD=0.65
SPOOF_THRESHOLD=0.70
RECOGNITION_BUFFER_EXPECTED_CANDIDATES=5

# ============================================================
#  Pipeline — GPU vs CPU
#  REQUIREMENTS_FILE controls which requirements-*.txt is used:
#    - requirements-cpu.txt  (onnxruntime)
#    - requirements-gpu.txt  (onnxruntime-gpu)
# ============================================================
PIPELINE_REQUIREMENTS=requirements-gpu.txt

# ============================================================
#  Camera Sources (RTSP streams)
#  Separate multiple cameras with pipe: |
# ============================================================
CAMERA_SOURCES=rtsp://mediamtx:8554/mystream
MOTION_THRESHOLD=0.02
FRAME_INTERVAL=0.1
DEBUG=false
MAX_INITIAL_SNAPSHOTS=5
MAX_FACE_YAW_DEG=45.0
MIN_FACE_SHARPNESS=150.0
MIN_FACE_DETECTION_CONFIDENCE=0.65
MIN_FACE_BRIGHTNESS=65.0
