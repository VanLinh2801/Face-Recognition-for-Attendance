# Copy this file to benchmarks/.env.benchmark and adjust paths for your machine.

# Model paths (shared across benchmarks)
SCRFD_MODEL_PATH=apps/pipeline/app/models/scrfd_2.5g_bnkps.onnx
INSIGHTFACE_MODEL_DIR=apps/ai_service/models/insightface
INSIGHTFACE_MODEL_NAME=antelopev2
INSIGHTFACE_RECOGNITION_MODEL_FILE=glintr100.onnx
INSIGHTFACE_CTX_ID=-1

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=person_faces

# ── Accuracy benchmark (benchmarks/accuracy/benchmark_accuracy.py) ─────────────
# Data layout:
#     enrolled/<IDENTITY>/   <- original registration frame, normally 1 face
#     genuine/<IDENTITY>/    <- camera frames containing that enrolled identity
#     impostor/<STRANGER>/   <- camera frames containing no enrolled identity
#   Set BENCH_ACCURACY_APPLY_QUALITY_FILTER=false when these frames were already
#   selected from pipeline quality-passed captures.
#   bench_data/accuracy/
#     enrolled/<IDENTITY>/   ← 1-5 ảnh đăng ký gốc mỗi người (chưa crop)
#     genuine/<IDENTITY>/    ← ảnh pipeline-crop của đúng người (tên khớp enrolled)
#     impostor/<STRANGER>/   ← ảnh pipeline-crop của người lạ (không có trong enrolled)
BENCH_ACCURACY_DATA_DIR=bench_data/accuracy
BENCH_ACCURACY_QDRANT_COLLECTION=bench_accuracy_temp
BENCH_ACCURACY_THRESHOLD=0.70
BENCH_ACCURACY_KEEP_COLLECTION=false
BENCH_ACCURACY_APPLY_QUALITY_FILTER=false
BENCH_ACCURACY_SUMMARY_OUTPUT=bench_results/accuracy/summary.json
BENCH_ACCURACY_SAMPLES_OUTPUT=bench_results/accuracy/samples.jsonl
BENCH_ACCURACY_ROC_OUTPUT=bench_results/accuracy/roc.json

# ── End-to-end pipeline latency (benchmarks/e2e/benchmark_e2e_pipeline.py) ─────
# Data layout:
#   bench_data/e2e/frames/   ← full frame camera (KHÔNG phải face crop)
#                              Extract từ video: ffmpeg -i video.mp4 -q:v 2 %04d.jpg
BENCH_E2E_FRAMES_DIR=bench_data/e2e/frames
BENCH_E2E_INCLUDE_QDRANT=false
BENCH_E2E_WARMUP=5
BENCH_E2E_LIMIT=0
BENCH_E2E_SUMMARY_OUTPUT=bench_results/e2e/summary.json
BENCH_E2E_FRAMES_OUTPUT=bench_results/e2e/frames.jsonl

# ── System resource monitor (benchmarks/system/monitor_resources.py) ────────────
# Chạy song song với accuracy hoặc e2e để capture GPU/RAM/CPU trong lúc benchmark
BENCH_RESOURCE_DURATION_SEC=300
BENCH_RESOURCE_INTERVAL_SEC=1
BENCH_RESOURCE_OUTPUT=bench_results/system/resources.jsonl
BENCH_RESOURCE_PROCESS_NAMES=
