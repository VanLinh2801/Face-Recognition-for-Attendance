# Copy this file to benchmarks/.env.benchmark and adjust paths for your machine.

# Shared benchmark data paths
BENCH_INPUT_DIR=bench_data/frames
BENCH_OUTPUT_DIR=bench_data/prepared_faces
BENCH_MANIFEST=bench_data/prepared_faces.jsonl
BENCH_RESULTS_DIR=bench_results

# Pipeline preparation benchmark
SCRFD_MODEL_PATH=apps/pipeline/app/models/scrfd_2.5g_bnkps.onnx
BENCH_MAX_IMAGES=0
BENCH_ALL_FACES=false

# AI service stage benchmark
INSIGHTFACE_MODEL_DIR=apps/ai_service/models/insightface
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_RECOGNITION_MODEL_FILE=w600k_r50.onnx
INSIGHTFACE_CTX_ID=-1
BENCH_WARMUP=20
BENCH_REPEAT=5
BENCH_LIMIT=0
BENCH_INCLUDE_QDRANT=false
BENCH_AI_SUMMARY_OUTPUT=bench_results/ai_service/buffalo_l_ai_stages.json
BENCH_AI_SAMPLES_OUTPUT=bench_results/ai_service/buffalo_l_ai_samples.jsonl

# Qdrant is only needed when BENCH_INCLUDE_QDRANT=true or --include-qdrant is used.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=person_faces

# Resource monitor benchmark
BENCH_RESOURCE_DURATION_SEC=300
BENCH_RESOURCE_INTERVAL_SEC=1
BENCH_RESOURCE_OUTPUT=bench_results/system/resources.jsonl
BENCH_RESOURCE_PROCESS_NAMES=
