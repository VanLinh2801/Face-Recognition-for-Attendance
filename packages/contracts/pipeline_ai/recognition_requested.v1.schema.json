{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "packages/contracts/pipeline_ai/recognition_requested.v1.schema.json",
  "allOf": [
    {
      "$ref": "../common/envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "event_name": {
          "const": "recognition.requested"
        },
        "event_version": {
          "const": "1.0.0"
        },
        "producer": {
          "const": "pipeline"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "stream_id",
            "frame_id",
            "frame_sequence",
            "captured_at",
            "presentation_ts_ms",
            "frame_width",
            "frame_height",
            "faces"
          ],
          "properties": {
            "stream_id": {
              "type": "string",
              "minLength": 1
            },
            "frame_id": {
              "type": "string",
              "minLength": 1
            },
            "frame_sequence": {
              "type": "integer",
              "minimum": 0
            },
            "captured_at": {
              "type": "string",
              "format": "date-time"
            },
            "presentation_ts_ms": {
              "type": "integer",
              "minimum": 0
            },
            "frame_width": {
              "type": "integer",
              "minimum": 1
            },
            "frame_height": {
              "type": "integer",
              "minimum": 1
            },
            "faces": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "track_id",
                  "bbox",
                  "face_media_asset"
                ],
                "properties": {
                  "track_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "bbox": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "x",
                      "y",
                      "width",
                      "height"
                    ],
                    "properties": {
                      "x": {
                        "type": "number"
                      },
                      "y": {
                        "type": "number"
                      },
                      "width": {
                        "type": "number",
                        "minimum": 0
                      },
                      "height": {
                        "type": "number",
                        "minimum": 0
                      }
                    }
                  },
                  "face_media_asset": {
                    "$ref": "../common/media_asset_ref.schema.json"
                  },
                  "detection_confidence": {
                    "type": [
                      "number",
                      "null"
                    ],
                    "minimum": 0,
                    "maximum": 1
                  },
                  "quality_status": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "enum": [
                      "passed",
                      "marginal",
                      "failed",
                      null
                    ]
                  },
                  "pipeline_metadata": {
                    "type": [
                      "object",
                      "null"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
